# Copy this to .env and fill in your values. DO NOT commit .env to git.
#
# This project has two runtimes with different env needs:
#   1. The Render dashboard/store  (server.js)
#   2. The VPS trading agent        (vps-agent.mjs / warmup.mjs)

# ── Render dashboard/store (server.js) ────────────────────────────────────────
PORT=3000
# Shared secret the VPS agent sends on /api/push and /api/pending. Required in
# production so only your VPS can post trades/account data. Must match the VPS.
PUSH_SECRET=choose_a_long_random_string
# Optional: protect the dashboard UI/API with HTTP Basic Auth (any username).
DASHBOARD_PASSWORD=
# Robinhood account number shown in the dashboard.
ROBINHOOD_ACCOUNT=545721409
# Optional protective circuit breaker: max realized loss (USD) allowed per ET day.
# If the day's realized P&L hits -this, the agent auto-disables until tomorrow.
# Leave blank or 0 to disable the breaker.
DAILY_LOSS_LIMIT=

# ── VPS trading agent (vps-agent.mjs / warmup.mjs) ────────────────────────────
# These live in the VPS .env (see setup-vps.sh), not the Render service.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# RENDER_URL=https://spy-trader.onrender.com
# PUSH_SECRET=must_match_the_render_value_above
# ROBINHOOD_ACCOUNT=545721409
# AUTO_PROMOTE=1   # let the weekly review auto-apply SAFE param changes that pass
#                  # the shadow-test (entry-window/signals/delta only; never risk
#                  # params). Omit or set 0 to keep changes suggestion-only.
#                  # Revert any change by deleting params.json on the VPS.
